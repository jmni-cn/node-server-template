{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "paths": {
      "@core/common": ["libs/core/common/src/index.ts"],
      "@core/common/*": ["libs/core/common/src/*"],
      "@core/config": ["libs/core/config/src/index.ts"],
      "@core/config/*": ["libs/core/config/src/*"],
      "@core/database": ["libs/core/database/src/index.ts"],
      "@core/database/*": ["libs/core/database/src/*"],
      "@core/logger": ["libs/core/logger/src/index.ts"],
      "@core/logger/*": ["libs/core/logger/src/*"],
      "@core/request-context": ["libs/core/request-context/src/index.ts"],
      "@core/request-context/*": ["libs/core/request-context/src/*"],
      "@core/i18n": ["libs/core/i18n/src/index.ts"],
      "@core/i18n/*": ["libs/core/i18n/src/*"],

      "@platform/auth": ["libs/platform/auth/src/index.ts"],
      "@platform/auth/*": ["libs/platform/auth/src/*"],
      "@platform/security": ["libs/platform/security/src/index.ts"],
      "@platform/security/*": ["libs/platform/security/src/*"],
      "@platform/cache": ["libs/platform/cache/src/index.ts"],
      "@platform/cache/*": ["libs/platform/cache/src/*"],
      "@platform/queue": ["libs/platform/queue/src/index.ts"],
      "@platform/queue/*": ["libs/platform/queue/src/*"],
      "@platform/audit": ["libs/platform/audit/src/index.ts"],
      "@platform/audit/*": ["libs/platform/audit/src/*"],
      "@platform/task": ["libs/platform/task/src/index.ts"],
      "@platform/task/*": ["libs/platform/task/src/*"],
      "@platform/health": ["libs/platform/health/src/index.ts"],
      "@platform/health/*": ["libs/platform/health/src/*"],

      "@domains/identity": ["libs/domains/identity/src/index.ts"],
      "@domains/identity/*": ["libs/domains/identity/src/*"],
      "@domains/access-control": ["libs/domains/access-control/src/index.ts"],
      "@domains/access-control/*": ["libs/domains/access-control/src/*"],
      "@domains/system": ["libs/domains/system/src/index.ts"],
      "@domains/system/*": ["libs/domains/system/src/*"],

      "@integrations/sso": ["libs/integrations/sso/src/index.ts"],
      "@integrations/sso/*": ["libs/integrations/sso/src/*"]
    }
  }
}
