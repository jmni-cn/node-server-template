# ============================================================
# Shared environment variables (all apps)
# Copy to env/<app>.local.env for local dev, or inject in prod.
# ============================================================

NODE_ENV=development
APP_NAME=admin-api

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=false

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT (secrets must be >= 32 chars; see jwtConfig Joi schema) ----
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# 「记住我」(optional)
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
# Refresh cookie (user-api)
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=.example.com

# ---- Logging ----
LOG_LEVEL=info

# ---- i18n ----
DEFAULT_LANGUAGE=zh-CN
