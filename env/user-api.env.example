# ============================================================
# user-api — 生产环境变量模板
# ------------------------------------------------------------
# 用法：cp env/user-api.env.example env/user-api.env，填真实值；
#       由 docker-compose.prod.yml 的 user-api 服务通过 env_file 注入。
# 后缀：*.local.env 本地 / *.dev.env docker dev / *.env 生产。
# ============================================================

NODE_ENV=production
APP_NAME=user-api

# ---- Database (MySQL，外部托管) ----
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=app
DB_PASSWORD=__CHANGE_ME__
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=20
DB_LOGGING=false

# ---- Redis (外部托管) ----
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_DB=0

# ---- JWT（必填，>= 32 字符）----
JWT_ACCESS_SECRET=__CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARS__
JWT_REFRESH_SECRET=__CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
# 生产 https，refresh cookie 必须 secure
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=.example.com

# ---- 凭证加密盐（务必随机）----
CREDENTIAL_ENCRYPTION_SALT=__CHANGE_ME_RANDOM_SALT__

# ---- CORS ----
CORS_ENABLED=true
CORS_ORIGIN=https://app.example.com

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY_PRINT=false
LOG_FILE_ENABLED=false

# ---- user-api HTTP ----
USER_API_PORT=3002
USER_API_PREFIX=
USER_SWAGGER_ENABLED=false
USER_SWAGGER_PATH=docs

# ============================================================
# SSO（可选）—— 按需开启对应 provider。
# ============================================================
# SSO_ISSUER=https://idp.example.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=https://app.example.com/sso/oidc/callback
# SSO_SCOPE=openid profile email
# SSO_MICROSOFT_TENANT_ID=common
# SSO_MICROSOFT_CLIENT_ID=
# SSO_MICROSOFT_CLIENT_SECRET=
# SSO_MICROSOFT_REDIRECT_URI=https://app.example.com/sso/microsoft/callback
# SSO_POST_LOGIN_REDIRECT=https://app.example.com/login/callback
# SSO_LOGIN_CODE_TTL=60
