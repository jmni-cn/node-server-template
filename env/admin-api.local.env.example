# ============================================================
# admin-api — 本地开发环境变量
# ------------------------------------------------------------
# 由 `npm run start:dev:admin` 加载：
#   cross-env NODE_ENV=development APP_NAME=admin-api → AppConfigModule
#   读取 env/admin-api.local.env（见 libs/core/config/src/config.module.ts）。
#
# 说明：
# - NODE_ENV / APP_NAME 已由 npm 脚本经 cross-env 注入，文件内无需重复（保留注释供参考）。
# - 本文件被 .gitignore（env/*.local.env），可安全填写本地真实值。
# - 这是「容器/进程启动后」由 Node 应用读取的运行期变量，与 docker compose 层变量不同。
# - DB_HOST / REDIS_HOST 指向本机映射端口（docker-compose.dev.yml 暴露的 3306 / 6379）。
# ============================================================

# NODE_ENV=development        # 由 start:dev:admin 注入
# APP_NAME=admin-api          # 由 start:dev:admin 注入；同时作为日志 service 名

# ---- Database (MySQL) ----  appConfig 之外，由 databaseConfig / typeorm-options.factory 读取
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=true
# DB_CHARSET / DB_COLLATION / DB_TIMEZONE 一般用默认值，无需覆盖

# ---- Redis ----  redisConfig；queueConfig 缺省也回退到这些值
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----  jwtConfig（Joi: JWT_ACCESS_SECRET / JWT_REFRESH_SECRET 必填，>= 32 字符）
JWT_ACCESS_SECRET=dev-admin-access-secret-please-change-32+
JWT_REFRESH_SECRET=dev-admin-refresh-secret-please-change-32+
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=.example.com

# ---- admin-api HTTP（应用启动期读取，main.ts / bootstrap）----
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=admin
ADMIN_SWAGGER_ENABLED=true
ADMIN_SWAGGER_PATH=docs
# Swagger 入口：http://localhost:3001/admin/docs

# ---- CORS ----  main.ts 读取 CORS_ENABLED / CORS_ORIGIN（appConfig 同名校验）
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Logging ----  loggerConfig
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false
# SERVICE_NAME 缺省回退 APP_NAME；如需自定义日志 service 名再设置
# SERVICE_NAME=admin-api

# ---- i18n ----  默认 zh-CN（注意：i18nConfig 目前用常量，env 不生效，保留以备启用）
# I18N_DEFAULT_LANGUAGE=zh-CN
# I18N_FALLBACK_LANGUAGE=en

# ---- 凭证加密盐 ----  libs/core/common crypto.util（外部账号 token 加密）
# 生产必须设置为高强度随机值；本地可用默认。
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod

# ---- 安全 / 风控 ----
# 登录锁定与 IP 自动封禁阈值不再走 env：基线即代码默认（security.module 注册表），
# 如需调整在后台改 system_configs（DB 覆盖，热更新），无需重启。
