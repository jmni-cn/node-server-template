# ============================================================
# user-api — docker dev 环境变量（容器化开发栈）
# ------------------------------------------------------------
# 由 docker/docker-compose.dev.yml 的 user-api 服务通过 env_file 注入。
# 与 *.local.env 区别：DB_HOST / REDIS_HOST 指向 compose 服务名。
#
# 后缀约定：*.local.env 本地 / *.dev.env docker dev / *.env 生产。
# ============================================================

NODE_ENV=development
APP_NAME=user-api

# ---- Database (MySQL) ----
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=true

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT（>= 32 字符）----
JWT_ACCESS_SECRET=dev-user-access-secret-please-change-32++
JWT_REFRESH_SECRET=dev-user-refresh-secret-please-change-32++
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax

# ---- user-api HTTP ----
USER_API_PORT=3002
USER_API_PREFIX=
USER_SWAGGER_ENABLED=true
USER_SWAGGER_PATH=docs

# ---- CORS ----
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false

# ---- 凭证加密盐 ----
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod

# ---- 安全 / 风控 ----
# 登录锁定与 IP 自动封禁阈值不再走 env：基线即代码默认，需调整走 DB 覆盖（system_configs，热更新）。

# ============================================================
# SSO（可选）—— 同 user-api.local.env，按需取消注释填写。
# ============================================================
# SSO_ISSUER=https://idp.example.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=http://localhost:3002/sso/oidc/callback
# SSO_SCOPE=openid profile email
