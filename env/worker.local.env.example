# ============================================================
# worker — 本地开发环境变量
# ------------------------------------------------------------
# 由 `npm run start:dev:worker` 加载：
#   cross-env NODE_ENV=development APP_NAME=worker → AppConfigModule
#   读取 env/worker.local.env。
#
# worker 无对外 HTTP（无 *_API_PORT / Swagger）。它消费 BullMQ 队列并执行 cron，
# 因此重点是 DB / Redis / QUEUE / WORKER_*。
# 注意：worker 仍加载同一套 config 校验，JWT 密钥依然必填（否则 Joi 校验失败）。
# ============================================================

# NODE_ENV=development        # 由 start:dev:worker 注入
# APP_NAME=worker             # 由 start:dev:worker 注入

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=false

# ---- Redis ----（BullMQ 连接缺省回退到 REDIS_*）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Queue (BullMQ) ----  queueConfig；如需与业务缓存隔离可单独指定 QUEUE_REDIS_*
QUEUE_CONCURRENCY=5
# QUEUE_REDIS_HOST=127.0.0.1
# QUEUE_REDIS_PORT=6379
# QUEUE_REDIS_PASSWORD=
# QUEUE_REDIS_DB=1

# ---- Worker 运行参数（setup-worker / app.module 直接读 process.env）----
WORKER_CONCURRENCY=5
WORKER_ENABLE_SCHEDULE=true
WORKER_HEALTH_PORT=3003

# ---- JWT ----  worker 不签发 token，但 config 校验要求其存在
JWT_ACCESS_SECRET=dev-worker-access-secret-please-change-32+
JWT_REFRESH_SECRET=dev-worker-refresh-secret-please-change-32+

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false

# ---- 凭证加密盐（异步任务若处理外部账号 token 会用到，建议与 API 一致）----
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod
