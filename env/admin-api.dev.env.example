# ============================================================
# admin-api — docker dev 环境变量（容器化开发栈）
# ------------------------------------------------------------
# 由 docker/docker-compose.dev.yml 的 admin-api 服务通过 env_file 注入。
#   docker compose -f docker/docker-compose.dev.yml --profile apps up
#
# 与 *.local.env 的唯一区别：DB_HOST / REDIS_HOST 指向 compose 内的服务名
# （mysql / redis），而非宿主机 127.0.0.1。其余沿用开发档（debug 日志、
# 开启 Swagger、开发用密钥）。
#
# 三套环境后缀约定：
#   *.local.env  本地非容器开发（npm run start:dev:*，连 127.0.0.1）
#   *.dev.env    docker dev 栈（本文件，连容器服务名）
#   *.env        生产（连托管服务，密钥需替换）
# ============================================================

NODE_ENV=development
APP_NAME=admin-api

# ---- Database (MySQL) ----  指向 compose 服务名 mysql
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=true

# ---- Redis ----  指向 compose 服务名 redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT（>= 32 字符）----
JWT_ACCESS_SECRET=dev-admin-access-secret-please-change-32+
JWT_REFRESH_SECRET=dev-admin-refresh-secret-please-change-32+
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax

# ---- admin-api HTTP ----
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=admin
ADMIN_SWAGGER_ENABLED=true
ADMIN_SWAGGER_PATH=docs

# ---- CORS ----
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false

# ---- 凭证加密盐 ----
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod

# ---- 安全 / 风控 ----
# 登录锁定与 IP 自动封禁阈值不再走 env：基线即代码默认，需调整走 DB 覆盖（system_configs，热更新）。
