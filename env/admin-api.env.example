# ============================================================
# admin-api — 生产环境变量模板
# ------------------------------------------------------------
# 用法：复制为 env/admin-api.env，填真实值；由 docker-compose.prod.yml
#       的 admin-api 服务通过 env_file 注入。
#   cp env/admin-api.env.example env/admin-api.env
#
# 三套环境后缀：*.local.env 本地 / *.dev.env docker dev / *.env 生产。
# 注意：env/admin-api.env 已被 .gitignore，严禁提交真实密钥。
# 生产 NODE_ENV=production，应用不读 env 文件，全靠容器进程环境变量（即本文件经 docker 注入）。
# MySQL / Redis 为外部托管服务，HOST 必须指向真实地址。
# ============================================================

NODE_ENV=production
APP_NAME=admin-api

# ---- Database (MySQL，外部托管) ----
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=app
DB_PASSWORD=__CHANGE_ME__
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=20
DB_LOGGING=false

# ---- Redis (外部托管) ----
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_DB=0

# ---- JWT（必填，>= 32 字符，用 `openssl rand -base64 48`）----
JWT_ACCESS_SECRET=__CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARS__
JWT_REFRESH_SECRET=__CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=.example.com

# ---- 凭证加密盐（务必随机）----
CREDENTIAL_ENCRYPTION_SALT=__CHANGE_ME_RANDOM_SALT__

# ---- 安全 / 风控 ----
# 登录锁定与 IP 自动封禁阈值不再走 env：基线即代码默认，需调整走 DB 覆盖（system_configs，热更新）。

# ---- CORS（逗号分隔，禁止 *）----
CORS_ENABLED=true
CORS_ORIGIN=https://admin.example.com

# ---- Logging（结构化 JSON）----
LOG_LEVEL=info
LOG_PRETTY_PRINT=false
LOG_FILE_ENABLED=false

# ---- admin-api HTTP ----
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=admin
ADMIN_SWAGGER_ENABLED=false
ADMIN_SWAGGER_PATH=docs
