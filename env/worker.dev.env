# ============================================================
# worker — docker dev 环境变量（容器化开发栈）
# ------------------------------------------------------------
# 由 docker/docker-compose.dev.yml 的 worker 服务通过 env_file 注入。
# 与 *.local.env 区别：DB_HOST / REDIS_HOST 指向 compose 服务名。
#
# 后缀约定：*.local.env 本地 / *.dev.env docker dev / *.env 生产。
# ============================================================

NODE_ENV=development
APP_NAME=worker

# ---- Database (MySQL) ----
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=false

# ---- Redis ----（BullMQ 连接缺省回退 REDIS_*）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Queue (BullMQ) ----
QUEUE_CONCURRENCY=5

# ---- Worker 运行参数 ----
WORKER_CONCURRENCY=5
WORKER_ENABLE_SCHEDULE=true
WORKER_HEALTH_PORT=3003

# ---- JWT（worker 不签发，但 config 校验要求存在，>= 32 字符）----
JWT_ACCESS_SECRET=dev-worker-access-secret-please-change-32+
JWT_REFRESH_SECRET=dev-worker-refresh-secret-please-change-32+

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false

# ---- 凭证加密盐 ----
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod
