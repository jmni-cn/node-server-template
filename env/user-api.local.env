# ============================================================
# user-api — 本地开发环境变量
# ------------------------------------------------------------
# 由 `npm run start:dev:user` 加载：
#   cross-env NODE_ENV=development APP_NAME=user-api → AppConfigModule
#   读取 env/user-api.local.env。
#
# 与 admin-api 共用 libs/core/config 的校验 Schema：JWT 密钥同样必填。
# DB / Redis 通常与 admin-api 指向同一套本地基础设施。
# ============================================================

# NODE_ENV=development        # 由 start:dev:user 注入
# APP_NAME=user-api           # 由 start:dev:user 注入

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=10
DB_LOGGING=true

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----  user-api 同时使用 refresh cookie，cookie 选项在此生效
JWT_ACCESS_SECRET=dev-user-access-secret-please-change-32++
JWT_REFRESH_SECRET=dev-user-refresh-secret-please-change-32++
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ACCESS_EXPIRES_IN=30m
JWT_REMEMBER_REFRESH_EXPIRES_IN=30d
# 本地 http，cookie 不能开 secure；线上 https 必须改 true
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=.example.com

# ---- user-api HTTP（应用启动期读取）----
USER_API_PORT=3002
# user-api 默认无前缀（USER_API_PREFIX 默认 ''）
USER_API_PREFIX=
USER_SWAGGER_ENABLED=true
USER_SWAGGER_PATH=docs
# Swagger 入口：http://localhost:3002/docs

# ---- CORS ----
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true
LOG_FILE_ENABLED=false

# ---- 凭证加密盐（外部账号绑定/解绑会用到）----
CREDENTIAL_ENCRYPTION_SALT=dev-credential-salt-change-in-prod

# ============================================================
# SSO — 全部可选，未配置不影响启动；按需取消注释填写。
# 内置 provider：oidc（通用单 IdP）/ microsoft / krafton
# ============================================================
# ---- 通用 OIDC（oidc provider）----
# SSO_ISSUER=https://idp.example.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=http://localhost:3002/sso/oidc/callback
# SSO_SCOPE=openid profile email
#
# ---- Microsoft Entra v2.0 ----
# SSO_MICROSOFT_TENANT_ID=common
# SSO_MICROSOFT_CLIENT_ID=
# SSO_MICROSOFT_CLIENT_SECRET=
# SSO_MICROSOFT_REDIRECT_URI=http://localhost:3002/sso/microsoft/callback
#
# ---- 登录后重定向 / 一次性登录码 ----
# SSO_POST_LOGIN_REDIRECT=http://localhost:3000/login/callback
# SSO_LOGIN_CODE_TTL=60
