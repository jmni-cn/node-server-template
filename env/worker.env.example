# ============================================================
# worker — 生产环境变量模板
# ------------------------------------------------------------
# 用法：cp env/worker.env.example env/worker.env，填真实值；
#       由 docker-compose.prod.yml 的 worker 服务通过 env_file 注入。
# 后缀：*.local.env 本地 / *.dev.env docker dev / *.env 生产。
# ============================================================

NODE_ENV=production
APP_NAME=worker

# ---- Database (MySQL，外部托管) ----
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=app
DB_PASSWORD=__CHANGE_ME__
DB_DATABASE=app_template
DB_CONNECTION_LIMIT=20
DB_LOGGING=false

# ---- Redis (外部托管) ----（BullMQ 连接缺省回退 REDIS_*）
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_DB=0

# ---- Queue (BullMQ) ----
QUEUE_CONCURRENCY=10
# QUEUE_REDIS_HOST=
# QUEUE_REDIS_PORT=
# QUEUE_REDIS_PASSWORD=
# QUEUE_REDIS_DB=1

# ---- Worker 运行参数 ----
WORKER_CONCURRENCY=10
WORKER_ENABLE_SCHEDULE=true
WORKER_HEALTH_PORT=3003

# ---- JWT（worker 不签发，但 config 校验要求存在，>= 32 字符）----
JWT_ACCESS_SECRET=__CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARS__
JWT_REFRESH_SECRET=__CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS__

# ---- 凭证加密盐（与 API 保持一致）----
CREDENTIAL_ENCRYPTION_SALT=__CHANGE_ME_RANDOM_SALT__

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY_PRINT=false
LOG_FILE_ENABLED=false
