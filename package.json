{
  "name": "node-server-template",
  "version": "1.0.0",
  "description": "NestJS + TypeORM Monorepo Platform Template (admin-api + user-api + worker)",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:admin": "cross-env APP_NAME=admin-api node dist/apps/admin-api/main",
    "start:user": "cross-env APP_NAME=user-api node dist/apps/user-api/main",
    "start:worker": "cross-env APP_NAME=worker node dist/apps/worker/main",

    "start:dev:admin": "cross-env NODE_ENV=development APP_NAME=admin-api nest start admin-api --watch",
    "start:dev:user": "cross-env NODE_ENV=development APP_NAME=user-api nest start user-api --watch",
    "start:dev:worker": "cross-env NODE_ENV=development APP_NAME=worker nest start worker --watch",

    "start:debug:admin": "cross-env NODE_ENV=development APP_NAME=admin-api nest start admin-api --debug --watch",

    "build": "npm run build:admin && npm run build:user && npm run build:worker && node scripts/copy-i18n.js",
    "build:admin": "cross-env NODE_ENV=production APP_NAME=admin-api nest build admin-api && node scripts/copy-i18n.js",
    "build:user": "cross-env NODE_ENV=production APP_NAME=user-api nest build user-api && node scripts/copy-i18n.js",
    "build:worker": "cross-env NODE_ENV=production APP_NAME=worker nest build worker",

    "lint": "eslint \"{apps,libs,scripts,tools,database,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{apps,libs,scripts,tools,database,test}/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",

    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=\"(\\.e2e-spec\\.ts|\\.integration\\.spec\\.ts)$\"",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",

    "typeorm": "cross-env APP_NAME=admin-api ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:create": "cross-env ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",

    "seed": "cross-env NODE_ENV=development APP_NAME=admin-api ts-node -r tsconfig-paths/register database/seeds/seed.ts",
    "db:reset": "cross-env NODE_ENV=development APP_NAME=admin-api ts-node -r tsconfig-paths/register scripts/reset-db.ts",

    "check:boundaries": "ts-node -r tsconfig-paths/register scripts/check-boundaries.ts",
    "check:layers": "ts-node -r tsconfig-paths/register scripts/check-layer-rules.ts",
    "check:all": "npm run check:boundaries && npm run check:layers",

    "prepare": "husky || true"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^8.3.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.9",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.2",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.8.2",
    "joi": "^18.0.2",
    "jose": "^5.9.6",
    "mysql2": "^3.15.3",
    "nanoid": "^5.1.6",
    "nestjs-i18n": "^10.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.7",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack-node-externals": "^3.0.0"
  }
}
