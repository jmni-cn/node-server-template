# user-api specific env (merge with .env.example)
APP_NAME=user-api
USER_API_PORT=3002
USER_API_PREFIX=
USER_SWAGGER_ENABLED=true
USER_SWAGGER_PATH=docs

# ============================================================================
# SSO — 所有字段可选，未配置不影响启动；按需取消注释填写。
# 内置 provider：oidc / microsoft / krafton（krafton 为示例 provider）。
# 仅当对应 *_CLIENT_ID 非空时该 provider 才会被注册。
# ============================================================================

# ---- 通用 OIDC provider（:provider = oidc）----
# SSO_ISSUER=https://idp.example.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=http://localhost:3002/sso/oidc/callback
# SSO_SCOPE=openid profile email

# ---- Microsoft Entra v2.0 provider（:provider = microsoft）----
# SSO_MICROSOFT_TENANT_ID=common
# SSO_MICROSOFT_CLIENT_ID=
# SSO_MICROSOFT_CLIENT_SECRET=
# SSO_MICROSOFT_REDIRECT_URI=http://localhost:3002/sso/microsoft/callback
# SSO_MICROSOFT_SCOPE=openid profile email User.Read

# ---- KRAFTON OIDC provider（示例，:provider = krafton；删除安全）----
# SSO_KRAFTON_OIDC_HOST=https://accounts.example.com
# SSO_KRAFTON_CLIENT_ID=
# SSO_KRAFTON_CLIENT_SECRET=
# SSO_KRAFTON_REDIRECT_URI=http://localhost:3002/sso/krafton/callback
# SSO_KRAFTON_SCOPE=openid
# SSO_KRAFTON_USE_PKCE=false

# ---- 一次性登录码 / 登录后重定向 ----
# 配置后 SSO 回调将 302 跳转到 ${SSO_POST_LOGIN_REDIRECT}?code=<oneTimeCode>，
# 前端再 POST /sso/exchange 用 code 换取 access token（+ Refresh Cookie）。
# SSO_POST_LOGIN_REDIRECT=http://localhost:5173/sso/callback
# 一次性登录码 TTL（秒），默认 60。
# SSO_LOGIN_CODE_TTL=60
